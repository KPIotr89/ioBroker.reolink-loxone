{
  "env": {
    "es2021": true,
    "node": true,
    "mocha": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "indent": ["error", 4, { "SwitchCase": 1 }],
    "no-console": "off",
    "no-unused-vars": ["error", { "args": "none", "caughtErrors": "none" }],
    "quotes": ["error", "single", { "avoidEscape": true }],
    "semi": ["error", "always"]
  }
}
